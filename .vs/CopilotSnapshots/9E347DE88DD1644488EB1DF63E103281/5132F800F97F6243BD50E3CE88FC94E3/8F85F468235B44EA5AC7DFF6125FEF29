using System;
using Autodesk.Revit.Attributes;
using Autodesk.Revit.DB;
using Autodesk.Revit.UI;
using Autodesk.Revit.UI.Selection;
using ArcTool.Core.Utils; // Khai báo namespace để gọi Filter

namespace ArcTool.Core.Commands
{
    [Transaction(TransactionMode.Manual)]
    public class ArrangeDimensionCommand : IExternalCommand
    {
        public Result Execute(ExternalCommandData commandData, ref string message, ElementSet elements)
        {
            UIDocument uidoc = commandData.Application.ActiveUIDocument;
            Document doc = uidoc.Document;
            Autodesk.Revit.DB.View activeView = doc.ActiveView;

            // Khởi tạo Filter từ thư mục Utils
            LinearDimensionSelectionFilter dimFilter = new LinearDimensionSelectionFilter();

            try
            {
                // Bước 1: Pick đường Dim gốc (Baseline)
                Reference baseRef = uidoc.Selection.PickObject(ObjectType.Element, dimFilter, "1. Chọn Dimension ĐẦU TIÊN (Làm mốc gốc)...");
                Dimension baselineDim = doc.GetElement(baseRef) as Dimension;

                // Gộp tất cả thao tác vào 1 lần Undo
                using (TransactionGroup tg = new TransactionGroup(doc, "ArcTool: Arrange Dimensions"))
                {
                    tg.Start();

                    // Vòng lặp chọn liên tục
                    while (true)
                    {
                        Reference nextRef;
                        try
                        {
                            nextRef = uidoc.Selection.PickObject(ObjectType.Element, dimFilter, "2. Chọn Dimension TIẾP THEO (Nhấn ESC để kết thúc)...");
                        }
                        catch (Autodesk.Revit.Exceptions.OperationCanceledException)
                        {
                            break; // Thoát vòng lặp êm đẹp khi user nhấn ESC
                        }

                        Dimension nextDim = doc.GetElement(nextRef) as Dimension;

                        if (nextDim.Id == baselineDim.Id) continue;

                        // Thực thi di chuyển
                        MoveDimensionToMatchSnap(doc, activeView, baselineDim, nextDim);

                        // Cập nhật Baseline
                        baselineDim = nextDim;
                    }

                    tg.Assimilate();
                }

                return Result.Succeeded;
            }
            catch (Autodesk.Revit.Exceptions.OperationCanceledException)
            {
                return Result.Cancelled;
            }
            catch (Exception ex)
            {
                Autodesk.Revit.UI.TaskDialog.Show("ArcTool Error", $"Lỗi không xác định: {ex.Message}");
                return Result.Failed;
            }
        }

        private void MoveDimensionToMatchSnap(Document doc, View activeView, Dimension baselineDim, Dimension nextDim)
        {
            Line baseLine = baselineDim.Curve as Line;
            Line nextLine = nextDim.Curve as Line;

            if (baseLine == null || nextLine == null) return;

            DimensionType dimType = baselineDim.DimensionType;
            Parameter snapParam = dimType.LookupParameter("Dimension Line Snap Distance");
            if (snapParam == null) return;

            double snapDistanceInternal = snapParam.AsDouble();
            double requiredDistance = snapDistanceInternal * activeView.Scale;

            XYZ baseDirection = baseLine.Direction;
            XYZ viewNormal = activeView.ViewDirection;

            XYZ perpVector = baseDirection.CrossProduct(viewNormal).Normalize();
            XYZ diffVector = nextLine.Origin - baseLine.Origin;

            double currentDistance = diffVector.DotProduct(perpVector);
            double sign = currentDistance >= 0 ? 1.0 : -1.0;
            double desiredDistance = sign * requiredDistance;

            double moveOffset = desiredDistance - currentDistance;

            // Bỏ qua nếu sai số nhỏ (đã nằm đúng vị trí)
            if (Math.Abs(moveOffset) < 1e-5) return;

            XYZ translationVector = perpVector * moveOffset;

            using (Transaction t = new Transaction(doc, "Move Single Dim"))
            {
                t.Start();
                ElementTransformUtils.MoveElement(doc, nextDim.Id, translationVector);
                t.Commit();
            }
        }
    }
}