    /// <summary>
    /// Trạng thái sync của một ExcelMapping, trả về từ CheckForChanges().
    /// Immutable — UI layer đọc, không được sửa.
    /// </summary>
    public sealed class MappingSyncStatus
    {
        /// <summary>File Excel vẫn tồn tại tại FilePath đã lưu.</summary>
        public bool FileExists { get; }

        /// <summary>
        /// File Excel có thay đổi kể từ lần sync cuối không.
        /// Luôn false nếu FileExists = false — tránh false positive.
        /// </summary>
        public bool HasChanges { get; }

        /// <summary>
        /// Màu Status Dot để hiển thị trong DataGrid.
        /// Quy tắc: Yellow > Red > Green (thứ tự ưu tiên hiển thị vấn đề).
        /// </summary>
        public SyncDotColor DotColor =>
            !FileExists  ? SyncDotColor.Yellow  // file bị move/xóa
            : HasChanges ? SyncDotColor.Red      // file thay đổi chưa sync
                         : SyncDotColor.Green;   // đã sync

        public MappingSyncStatus(bool fileExists, bool hasChanges)
        {
            FileExists = fileExists;
            // Guard: HasChanges chỉ có nghĩa khi file tồn tại
            HasChanges = fileExists && hasChanges;
        }
    }

    /// <summary>Màu Status Dot — dùng để binding WPF Ellipse.Fill trong Phase 3.</summary>
    public enum SyncDotColor
    {
        Green,   // Synced — ellipse xanh lá
        Red,     // Has changes — ellipse đỏ
        Yellow   // File not found — ellipse vàng
    }

