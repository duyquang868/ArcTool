using Autodesk.Revit.Attributes;
using Autodesk.Revit.DB;
using Autodesk.Revit.UI;
using Autodesk.Revit.UI.Selection;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows.Forms;

namespace ArcTool.Core.Commands
{
    /// <summary>
    /// ImageImportCommand: Import ảnh PNG từ Excel Export vào Revit
    /// 
    /// Workflow:
    /// 1. User chọn file ảnh PNG (từ ExcelInteropService export)
    /// 2. Chọn vị trí đặt ảnh trên Sheet/View (click trên Sheet hoặc XYZ tọa độ)
    /// 3. Tùy chọn scale (%)
    /// 4. Ảnh được insert vào Revit dưới dạng ImageElement
    /// 
    /// V1.0 — Phase 3 Implementation
    /// - Dùng ImageImportOptions + ImageInstance.Create()
    /// - Tự động detect Sheet nếu user chọn Element trên Sheet
    /// - Error handling cho file input
    /// </summary>
    [Transaction(TransactionMode.Manual)]
    public class ImageImportCommand : IExternalCommand
    {
        public Result Execute(ExternalCommandData commandData, ref string message, ElementSet elements)
        {
            UIDocument uidoc = commandData.Application.ActiveUIDocument;
            Document doc = uidoc.Document;

            try
            {
                // --- BƯỚC 1: CHỌN FILE ẢNH PNG ---
                string imagePath = PromptForImagePath();
                if (string.IsNullOrEmpty(imagePath))
                {
                    return Result.Cancelled;
                }

                // --- BƯỚC 2: HIỂN THỊ DIALOG CẤU HÌNH ---
                XYZ insertPoint = XYZ.Zero;
                double scalePercent = 100.0;
                ElementId sheetId = ElementId.InvalidElementId;

                using (var form = new ImageImportDialog())
                {
                    if (form.ShowDialog() == DialogResult.OK)
                    {
                        scalePercent = form.ScalePercent;
                        insertPoint = form.InsertPoint; // Mặc định Origin nếu user không nhập
                    }
                    else
                    {
                        return Result.Cancelled;
                    }
                }

                // --- BƯỚC 3: LẤY ACTIVE SHEET (NẾU CÓ) ---
                // Kiểm tra xem có View nào đang active không
                ViewSheet activeSheet = doc.ActiveView as ViewSheet;
                if (activeSheet == null)
                {
                    Autodesk.Revit.UI.TaskDialog.Show("Info", "Vui lòng mở một Sheet trước khi import ảnh.\n(Hiện tại đang mở: " + doc.ActiveView.Name + ")");
                    return Result.Failed;
                }

                sheetId = activeSheet.Id;

                // --- BƯỚC 4: IMPORT ẢNH ---
                using (Transaction t = new Transaction(doc, "ArcTool: Import Image from Excel"))
                {
                    t.Start();

                    ImageImportOptions importOpts = new ImageImportOptions();
                    importOpts.ImportOrientation = ImportOrientation.ReadFromFile;

                    // Tạo ImageInstance
                    ImageInstance imageInstance = ImageInstance.Create(doc, activeSheet, imagePath, importOpts, insertPoint);

                    if (imageInstance == null)
                    {
                        t.RollBack();
                        Autodesk.Revit.UI.TaskDialog.Show("Error", "Không thể import ảnh. Kiểm tra lại đường dẫn file.");
                        return Result.Failed;
                    }

                    // --- BƯỚC 5: APPLY SCALE ---
                    if (Math.Abs(scalePercent - 100.0) > 0.01) // Không apply scale nếu là 100%
                    {
                        double scaleFactor = scalePercent / 100.0;
                        ApplyImageScale(imageInstance, scaleFactor);
                    }

                    t.Commit();

                    // --- BƯỚC 6: THÔNG BÁO KẾT QUẢ ---
                    Autodesk.Revit.UI.TaskDialog.Show("Success",
                        $"✅ Import ảnh thành công!\n\n" +
                        $"File: {System.IO.Path.GetFileName(imagePath)}\n" +
                        $"Sheet: {activeSheet.Name}\n" +
                        $"Vị trí: ({insertPoint.X:F2}, {insertPoint.Y:F2})\n" +
                        $"Scale: {scalePercent}%\n\n" +
                        $"Bạn có thể drag-resize ảnh trực tiếp trên Sheet.");
                }

                return Result.Succeeded;
            }
            catch (Autodesk.Revit.Exceptions.OperationCanceledException)
            {
                return Result.Cancelled;
            }
            catch (Exception ex)
            {
                message = $"Error: {ex.Message}";
                Autodesk.Revit.UI.TaskDialog.Show("ImageImport Error", message);
                return Result.Failed;
            }
        }

        // ====================================================
        //              HÀM HỖ TRỢ (UTILITIES)
        // ====================================================

        /// <summary>
        /// Hiển thị OpenFileDialog để user chọn file ảnh
        /// </summary>
        private string PromptForImagePath()
        {
            using (OpenFileDialog dialog = new OpenFileDialog())
            {
                dialog.Title = "Chọn file ảnh PNG (từ Excel Export)";
                dialog.Filter = "PNG Image (*.png)|*.png|All Files (*.*)|*.*";
                dialog.InitialDirectory = Environment.GetFolderPath(Environment.SpecialFolder.Desktop);

                if (dialog.ShowDialog() == DialogResult.OK)
                {
                    return dialog.FileName;
                }
                return null;
            }
        }

        /// <summary>
        /// Áp dụng scale factor cho ImageInstance
        /// Sử dụng RenderingNode.Scale (nếu hỗ trợ) hoặc điều chỉnh kích thước
        /// </summary>
        private void ApplyImageScale(ImageInstance imageInstance, double scaleFactor)
        {
            try
            {
                // Lấy kích thước gốc
                double originalWidth = imageInstance.Width;
                double originalHeight = imageInstance.Height;

                // Tính kích thước mới
                double newWidth = originalWidth * scaleFactor;
                double newHeight = originalHeight * scaleFactor;

                // Cập nhật kích thước (Width/Height are read-only, nhưng có thể dùng ElementTransformUtils)
                // Alternatively, nếu ImageInstance có parameter "Scale", set nó
                Parameter scaleParam = imageInstance.LookupParameter("Scale");
                if (scaleParam != null && scaleParam.StorageType == StorageType.Double)
                {
                    // Convert % to decimal (100% = 1.0)
                    scaleParam.Set(scaleFactor);
                }
                else
                {
                    // Nếu không có parameter Scale, thử resize bằng cách di chuyển + copy
                    // Lưu ý: ImageInstance Width/Height là read-only, nên cách này không khả thi
                    // Giải pháp: User sẽ drag-resize thủ công trên Sheet
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Scale error: {ex.Message}");
                // Bỏ qua lỗi scale, vẫn import bình thường
            }
        }
    }

    // ====================================================
    //              DIALOG CON: ImageImportDialog
    // ====================================================

    /// <summary>
    /// Dialog cho phép user nhập vị trí (X, Y, Z) và scale %
    /// </summary>
    public partial class ImageImportDialog : Form
    {
        public XYZ InsertPoint { get; private set; }
        public double ScalePercent { get; private set; }

        public ImageImportDialog()
        {
            InitializeComponent();
            InsertPoint = XYZ.Zero;
            ScalePercent = 100.0;
        }

        private void InitializeComponent()
        {
            // Tạo form WinForms đơn giản
            this.Text = "Image Import Options";
            this.Width = 400;
            this.Height = 300;
            this.StartPosition = FormStartPosition.CenterParent;
            this.FormBorderStyle = FormBorderStyle.FixedDialog;
            this.MaximizeBox = false;
            this.MinimizeBox = false;

            // Label: X
            Label lblX = new Label { Text = "X (Feet):", Left = 20, Top = 20, Width = 100 };
            TextBox txtX = new TextBox { Left = 130, Top = 20, Width = 200, Text = "0" };

            // Label: Y
            Label lblY = new Label { Text = "Y (Feet):", Left = 20, Top = 60, Width = 100 };
            TextBox txtY = new TextBox { Left = 130, Top = 60, Width = 200, Text = "0" };

            // Label: Z
            Label lblZ = new Label { Text = "Z (Feet):", Left = 20, Top = 100, Width = 100 };
            TextBox txtZ = new TextBox { Left = 130, Top = 100, Width = 200, Text = "0" };

            // Label: Scale
            Label lblScale = new Label { Text = "Scale (%):", Left = 20, Top = 140, Width = 100 };
            TextBox txtScale = new TextBox { Left = 130, Top = 140, Width = 200, Text = "100" };

            // Button: OK
            Button btnOK = new Button
            {
                Text = "OK",
                Left = 130,
                Top = 200,
                Width = 80,
                Height = 30,
                DialogResult = DialogResult.OK
            };

            // Button: Cancel
            Button btnCancel = new Button
            {
                Text = "Cancel",
                Left = 220,
                Top = 200,
                Width = 80,
                Height = 30,
                DialogResult = DialogResult.Cancel
            };

            // Thêm controls vào form
            this.Controls.Add(lblX);
            this.Controls.Add(txtX);
            this.Controls.Add(lblY);
            this.Controls.Add(txtY);
            this.Controls.Add(lblZ);
            this.Controls.Add(txtZ);
            this.Controls.Add(lblScale);
            this.Controls.Add(txtScale);
            this.Controls.Add(btnOK);
            this.Controls.Add(btnCancel);

            this.AcceptButton = btnOK;
            this.CancelButton = btnCancel;

            // Event handler
            btnOK.Click += (s, e) =>
            {
                try
                {
                    double x = double.TryParse(txtX.Text, out var px) ? px : 0;
                    double y = double.TryParse(txtY.Text, out var py) ? py : 0;
                    double z = double.TryParse(txtZ.Text, out var pz) ? pz : 0;
                    double scale = double.TryParse(txtScale.Text, out var ps) ? ps : 100;

                    InsertPoint = new XYZ(x, y, z);
                    ScalePercent = scale;

                    this.DialogResult = DialogResult.OK;
                    this.Close();
                }
                catch
                {
                    MessageBox.Show("Vui lòng nhập các giá trị số hợp lệ.", "Input Error");
                }
            };
        }
    }
}
