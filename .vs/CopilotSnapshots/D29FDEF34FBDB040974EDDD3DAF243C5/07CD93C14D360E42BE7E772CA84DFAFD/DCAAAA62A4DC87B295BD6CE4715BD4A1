using System;
using System.Runtime.InteropServices;
using System.Reflection;

namespace ArcTool.Core.Services
{
    public class ExcelInteropService : IDisposable
    {
        // Use dynamic object to avoid type conflicts between Excel COM versions
        private dynamic _excelApp;

        /// <summary>
        /// Connect to open Excel instance (Silent Mode)
        /// </summary>
        public bool AttachToActiveExcel()
        {
            try
            {
                // Method 1: Try direct Marshal.GetActiveObject call
                try
                {
                    _excelApp = Marshal.GetActiveObject("Excel.Application");
                    if (_excelApp != null)
                    {
                        return true;
                    }
                }
                catch { }

                // Method 2: Try using Running Object Table (ROT)
                try
                {
                    int hr = GetRunningObjectTable(0, out System.Runtime.InteropServices.ComTypes.IRunningObjectTable rot);
                    if (hr == 0 && rot != null)
                    {
                        rot.EnumRunning(out System.Runtime.InteropServices.ComTypes.IEnumMoniker enumMoniker);
                        System.Runtime.InteropServices.ComTypes.IMoniker[] monikers = new System.Runtime.InteropServices.ComTypes.IMoniker[1];

                        while (enumMoniker.Next(1, monikers, IntPtr.Zero) == 0)
                        {
                            rot.GetObject(monikers[0], out object obj);
                            if (obj != null && obj.GetType().Name == "_Application")
                            {
                                try
                                {
                                    // Verify it's Excel by checking for Workbooks property
                                    dynamic testApp = obj;
                                    if (testApp.Workbooks != null && testApp.Workbooks.Count >= 0)
                                    {
                                        _excelApp = obj;
                                        return true;
                                    }
                                }
                                catch { }
                            }
                            Marshal.ReleaseComObject(obj);
                        }
                        Marshal.ReleaseComObject(enumMoniker);
                        Marshal.ReleaseComObject(rot);
                    }
                }
                catch { }

                // Method 3: Reflection-based approach for GetActiveObject as last resort
                try
                {
                    var type = Type.GetType("System.Runtime.InteropServices.Marshal");
                    if (type != null)
                    {
                        var method = type.GetMethod("GetActiveObject",
                            BindingFlags.Public | BindingFlags.Static,
                            null, new[] { typeof(string) }, null);

                        if (method != null)
                        {
                            object obj = method.Invoke(null, new[] { "Excel.Application" });
                            if (obj != null)
                            {
                                _excelApp = obj;
                                return true;
                            }
                        }
                    }
                }
                catch { }

                return false; // Could not connect to existing Excel instance
            }
            catch
            {
                return false;
            }
        }

        // Import for ROT (Running Object Table)
        [DllImport("ole32.dll")]
        private static extern int GetRunningObjectTable(int reserved, out System.Runtime.InteropServices.ComTypes.IRunningObjectTable prot);

        /// <summary>
        /// Copy print range, Paste to Chart and Export to SVG
        /// </summary>
        public bool ExportSelectionToSvg(string outputSvgPath, out string errorMsg)
        {
            errorMsg = string.Empty;
            if (_excelApp == null)
            {
                errorMsg = "Mất kết nối với Excel.";
                return false;
            }

            dynamic wb = null;
            dynamic sheet = null;
            dynamic targetRange = null;
            dynamic tempChart = null;

            try
            {
                // 1. CHIẾN THUẬT TÌM WORKBOOK
                try
                {
                    // Cách 1: Thử lấy cái đang Active
                    wb = _excelApp.ActiveWorkbook;
                }
                catch { }

                // Cách 2: Nếu Active = null (do mất Focus), lấy cái đầu tiên trong danh sách
                if (wb == null && _excelApp.Workbooks.Count > 0)
                {
                    try
                    {
                        // Excel Index bắt đầu từ 1, không phải 0
                        wb = _excelApp.Workbooks[1];
                        wb.Activate(); // Bắt nó hiện lên để lấy Selection chuẩn
                    }
                    catch { }
                }

                if (wb == null)
                {
                    errorMsg = $"Không tìm thấy Workbook nào. (Excel báo đang mở {_excelApp.Workbooks.Count} file).";
                    return false;
                }

                sheet = wb.ActiveSheet;

                // 2. CHIẾN THUẬT TÌM RANGE
                try
                {
                    // Ưu tiên 1: Print Area
                    string printAreaAddress = sheet.PageSetup.PrintArea;
                    if (!string.IsNullOrEmpty(printAreaAddress))
                    {
                        targetRange = sheet.Range[printAreaAddress];
                    }
                }
                catch { }

                if (targetRange == null)
                {
                    // Ưu tiên 2: Selection
                    targetRange = _excelApp.Selection;

                    // Nếu chọn 1 ô trống -> Coi như chưa chọn
                    if (targetRange != null && targetRange.Count == 1)
                    {
                        try
                        {
                            if (string.IsNullOrEmpty(targetRange.Value2?.ToString()))
                            {
                                targetRange = null;
                            }
                        }
                        catch
                        {
                            targetRange = null;
                        }
                    }
                }

                if (targetRange == null)
                {
                    // Ưu tiên 3: UsedRange
                    targetRange = sheet.UsedRange;
                }

                if (targetRange == null)
                {
                    errorMsg = "Không xác định được vùng dữ liệu (PrintArea/Selection/UsedRange đều trống).";
                    return false;
                }

                // 3. THỰC HIỆN COPY & EXPORT
                // Use numeric constants to avoid enum conflicts
                const int xlScreen = 1;           // XlPictureAppearance.xlScreen
                const int xlPicture = 2;          // XlCopyPictureFormat.xlPicture
                const int xlBitmap = 1;           // XlCopyPictureFormat.xlBitmap

                // Quan trọng: CopyPicture có thể lỗi nếu Excel đang bận, ta thử 2 format
                try
                {
                    targetRange.CopyPicture(xlScreen, xlPicture);
                }
                catch
                {
                    // Thử lại với Bitmap nếu Picture lỗi
                    try
                    {
                        targetRange.CopyPicture(xlScreen, xlBitmap);
                    }
                    catch
                    {
                        errorMsg = "Không thể sao chép dữ liệu (CopyPicture failed).";
                        return false;
                    }
                }

                dynamic charts = sheet.ChartObjects();
                tempChart = charts.Add(0, 0, (double)targetRange.Width, (double)targetRange.Height);

                tempChart.Activate();

                // Thử paste (đôi khi clipboard chậm, cần thử lại)
                bool pasteSuccess = false;
                for (int i = 0; i < 3; i++) // Thử 3 lần
                {
                    try
                    {
                        tempChart.Chart.Paste();
                        pasteSuccess = true;
                        break;
                    }
                    catch
                    {
                        System.Threading.Thread.Sleep(200); // Chờ 200ms
                    }
                }

                if (!pasteSuccess)
                {
                    errorMsg = "Không thể Paste hình ảnh vào Chart (Lỗi Clipboard).";
                    return false;
                }

                tempChart.Chart.Export(outputSvgPath, "SVG");
                return true;
            }
            catch (Exception ex)
            {
                errorMsg = "Lỗi xử lý Excel: " + ex.Message;
                return false;
            }
            finally
            {
                // CLEANUP
                if (tempChart != null)
                {
                    try { tempChart.Delete(); }
                    catch { }
                }

                if (targetRange != null)
                {
                    try { Marshal.ReleaseComObject(targetRange); }
                    catch { }
                }

                if (sheet != null)
                {
                    try { Marshal.ReleaseComObject(sheet); }
                    catch { }
                }

                if (wb != null)
                {
                    try { Marshal.ReleaseComObject(wb); }
                    catch { }
                }
            }
        }

        public void Dispose()
        {
            if (_excelApp != null)
            {
                try
                {
                    Marshal.ReleaseComObject(_excelApp);
                }
                catch { }
                _excelApp = null;
            }
        }
    }
}
