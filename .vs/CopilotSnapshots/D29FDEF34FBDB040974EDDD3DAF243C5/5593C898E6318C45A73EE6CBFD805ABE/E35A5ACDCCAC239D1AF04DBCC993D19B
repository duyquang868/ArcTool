using Autodesk.Revit.Attributes;
using Autodesk.Revit.DB;
using Autodesk.Revit.UI;
using Autodesk.Revit.UI.Selection;
using System;
using System.Collections.Generic;
using System.Linq;

namespace ArcTool.Core.Commands
{
    [Transaction(TransactionMode.Manual)]
    public class MultiCutCommand : IExternalCommand
    {
        public Result Execute(ExternalCommandData commandData, ref string message, ElementSet elements)
        {
            UIDocument uidoc = commandData.Application.ActiveUIDocument;
            Document doc = uidoc.Document;

            try
            {
                // BƯỚC 1: CHỌN CÁC VOID (GENERIC MODEL)
                IList<Reference> voidRefs = null;
                try
                {
                    voidRefs = uidoc.Selection.PickObjects(ObjectType.Element, new VoidSelectionFilter(), "Bước 1: Quét chọn các Void");
                }
                catch (Autodesk.Revit.Exceptions.OperationCanceledException) { return Result.Cancelled; }

                if (voidRefs == null || voidRefs.Count == 0) return Result.Cancelled;

                List<Element> voids = voidRefs.Select(r => doc.GetElement(r)).ToList();

                // BƯỚC 2: CHỌN ĐỐI TƯỢNG BỊ CẮT (TƯỜNG + CỘT)
                IList<Reference> targetRefs = null;
                try
                {
                    // Đã nâng cấp bộ lọc để cho phép chọn cả Cột
                    targetRefs = uidoc.Selection.PickObjects(ObjectType.Element, new CutTargetSelectionFilter(), "Bước 2: Quét chọn Tường và Cột cần cắt");
                }
                catch (Autodesk.Revit.Exceptions.OperationCanceledException) { return Result.Cancelled; }

                if (targetRefs == null || targetRefs.Count == 0) return Result.Cancelled;

                List<Element> targetElements = targetRefs.Select(r => doc.GetElement(r)).ToList();

                // BƯỚC 3: XỬ LÝ CẮT
                using (Transaction t = new Transaction(doc, "ArcTool: Multi-Cut Walls & Columns"))
                {
                    t.Start();

                    int successCount = 0;
                    int totalVoids = voids.Count;

                    for (int i = 0; i < totalVoids; i++)
                    {
                        Element voidElem = voids[i];

                        // Cập nhật trạng thái
                        uidoc.Application.Application.WriteJournalComment($"Cutting Void {i + 1}/{totalVoids}", true);

                        // Lấy BoundingBox của Void để tìm đối tượng gần đó
                        BoundingBoxXYZ bb = voidElem.get_BoundingBox(null);
                        if (bb == null) continue;

                        Outline outline = new Outline(bb.Min, bb.Max);
                        BoundingBoxIntersectsFilter bbFilter = new BoundingBoxIntersectsFilter(outline);

                        // Lọc ra các đối tượng (Tường/Cột) nằm trong phạm vi của Void này
                        var nearbyTargets = targetElements.Where(e => bbFilter.PassesFilter(e)).ToList();

                        bool voidUsed = false;
                        foreach (Element target in nearbyTargets)
                        {
                            // Kiểm tra xem đối tượng này có hỗ trợ cắt bởi Void không
                            if (InstanceVoidCutUtils.CanBeCutWithVoid(target))
                            {
                                try
                                {
                                    // Kiểm tra xem đã cắt chưa
                                    if (!InstanceVoidCutUtils.IsVoidInstanceCuttingElement(voidElem, target))
                                    {
                                        InstanceVoidCutUtils.AddInstanceVoidCut(doc, target, voidElem);
                                        voidUsed = true;
                                    }
                                }
                                catch { }
                            }
                        }

                        if (voidUsed) successCount++;
                    }

                    doc.Regenerate();
                    t.Commit();

                    Autodesk.Revit.UI.TaskDialog.Show("Multi-Cut Result",
                        $"Hoàn tất!\n" +
                        $"- Số Void xử lý: {totalVoids}\n" +
                        $"- Số vị trí cắt thành công: {successCount}\n" +
                        $"(Bao gồm cả Tường và Cột)");
                }

                return Result.Succeeded;
            }
            catch (Exception ex)
            {
                message = ex.Message;
                return Result.Failed;
            }
        }

        // --- BỘ LỌC VOID (Giữ nguyên) ---
        public class VoidSelectionFilter : ISelectionFilter
        {
            public bool AllowElement(Element elem)
            {
                return elem.Category.Id.IntegerValue == (int)BuiltInCategory.OST_GenericModel;
            }
            public bool AllowReference(Reference reference, XYZ position) => false;
        }

        // --- BỘ LỌC MỚI: CHO PHÉP CHỌN TƯỜNG VÀ CỘT ---
        public class CutTargetSelectionFilter : ISelectionFilter
        {
            public bool AllowElement(Element elem)
            {
                if (elem.Category == null) return false;

                int catId = elem.Category.Id.IntegerValue;

                return catId == (int)BuiltInCategory.OST_Walls ||              // Tường
                       catId == (int)BuiltInCategory.OST_StructuralColumns ||  // Cột Kết cấu
                       catId == (int)BuiltInCategory.OST_Columns;              // Cột Kiến trúc
            }
            public bool AllowReference(Reference reference, XYZ position) => false;
        }
    }
}