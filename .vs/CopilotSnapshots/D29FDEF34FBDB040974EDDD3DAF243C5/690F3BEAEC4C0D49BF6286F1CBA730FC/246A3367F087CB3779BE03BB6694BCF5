using Autodesk.Revit.Attributes;
using Autodesk.Revit.DB;
using Autodesk.Revit.UI;
using Autodesk.Revit.UI.Selection;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows.Forms;

namespace ArcTool.Core.Commands
{
    [Transaction(TransactionMode.Manual)]
    public class CreateVoidFromLinkCommand : IExternalCommand
    {
        public Result Execute(ExternalCommandData commandData, ref string message, ElementSet elements)
        {
            UIDocument uidoc = commandData.Application.ActiveUIDocument;
            Document doc = uidoc.Document;

            try
            {
                // --- BƯỚC 1: HIỆN FORM CHỌN FAMILY VOID ---
                var genericModelSymbols = new FilteredElementCollector(doc)
                    .OfClass(typeof(FamilySymbol))
                    .OfCategory(BuiltInCategory.OST_GenericModel)
                    .Cast<FamilySymbol>()
                    .OrderBy(x => x.FamilyName)
                    .ToList();

                if (genericModelSymbols.Count == 0)
                {
                    Autodesk.Revit.UI.TaskDialog.Show("ArcTool Error", "Không tìm thấy Family Generic Model nào trong dự án.");
                    return Result.Failed;
                }

                FamilySymbol selectedVoidSymbol = null;
                using (var form = new FamilySelectionForm(genericModelSymbols))
                {
                    if (form.ShowDialog() == System.Windows.Forms.DialogResult.OK) selectedVoidSymbol = form.SelectedSymbol;
                    else return Result.Cancelled;
                }

                using (Transaction t = new Transaction(doc, "Activate Symbol"))
                {
                    t.Start();
                    if (!selectedVoidSymbol.IsActive) selectedVoidSymbol.Activate();
                    t.Commit();
                }

                // --- BƯỚC 2: CHỌN DẦM TỪ LINK ---
                Reference linkRef = uidoc.Selection.PickObject(ObjectType.LinkedElement, "Chọn dầm (Structural Framing) từ file Link");
                RevitLinkInstance linkInstance = doc.GetElement(linkRef.ElementId) as RevitLinkInstance;
                Document linkDoc = linkInstance.GetLinkDocument();
                Element linkedBeam = linkDoc.GetElement(linkRef.LinkedElementId);

                // --- BƯỚC 3: LẤY THÔNG SỐ ---
                FamilyInstance beamInstance = linkedBeam as FamilyInstance;
                if (beamInstance == null)
                {
                    Autodesk.Revit.UI.TaskDialog.Show("ArcTool Error", "Phần tử chọn không phải FamilyInstance.");
                    return Result.Failed;
                }

                FamilySymbol beamSymbol = beamInstance.Symbol;
                double beamWidth = GetParamValueFromSymbol(beamSymbol, new[] { "b", "Width", "B", "Rộng" });
                double beamHeight = GetParamValueFromSymbol(beamSymbol, new[] { "h", "Height", "H", "Depth", "Cao" });

                // Cố gắng lấy Length. Nếu Beam là Line-based, length có thể lấy từ LocationCurve chính xác hơn param "Cut Length"
                double beamLength = 0;
                LocationCurve locCurve = linkedBeam.Location as LocationCurve;
                if (locCurve != null)
                {
                    beamLength = locCurve.Curve.Length;
                }
                else
                {
                    beamLength = GetParamValue(linkedBeam, new[] { "Cut Length", "Length", "Chiều dài" });
                }

                if (beamWidth == 0 || beamHeight == 0 || beamLength == 0)
                {
                    Autodesk.Revit.UI.TaskDialog.Show("ArcTool Error", "Không lấy được kích thước dầm. Kiểm tra lại Family.");
                    return Result.Failed;
                }

                // --- BƯỚC 4: LẤY VỊ TRÍ CHÍNH XÁC (SỬA ĐỔI QUAN TRỌNG) ---

                // 1. Lấy Transform của Link (Link -> Host)
                Transform linkTransform = linkInstance.GetTotalTransform();

                // 2. Lấy Solid của dầm (trong toạ độ Local của Link) để tìm tâm hình học thực tế
                Solid beamSolid = GetSolidFromElement(linkedBeam);
                XYZ placementPoint = null;

                if (beamSolid != null && beamSolid.Volume > 0)
                {
                    // Lấy trọng tâm (Centroid) của khối Solid
                    XYZ localCentroid = beamSolid.ComputeCentroid();

                    // Chuyển đổi toạ độ từ Link sang Host
                    placementPoint = linkTransform.OfPoint(localCentroid);
                }
                else
                {
                    // Fallback: Nếu không lấy được Solid, dùng Location Curve (cách cũ)
                    if (locCurve != null)
                    {
                        XYZ start = linkTransform.OfPoint(locCurve.Curve.GetEndPoint(0));
                        XYZ end = linkTransform.OfPoint(locCurve.Curve.GetEndPoint(1));
                        placementPoint = (start + end) / 2.0;
                    }
                }

                if (placementPoint == null)
                {
                    TaskDialog.Show("Error", "Không xác định được vị trí đặt Void.");
                    return Result.Failed;
                }

                // Tính toán hướng xoay (Vẫn dựa vào Curve để lấy hướng X)
                XYZ beamDir = XYZ.BasisX;
                if (locCurve != null)
                {
                    XYZ start = linkTransform.OfPoint(locCurve.Curve.GetEndPoint(0));
                    XYZ end = linkTransform.OfPoint(locCurve.Curve.GetEndPoint(1));
                    beamDir = (end - start).Normalize();
                }

                // --- BƯỚC 5: CHỌN TƯỜNG & CẮT ---
                Reference wallRef = uidoc.Selection.PickObject(ObjectType.Element, new WallSelectionFilter(), "Chọn Tường cần cắt");
                Element wall = doc.GetElement(wallRef);

                using (Transaction t = new Transaction(doc, "ArcTool: Place Void & Cut"))
                {
                    t.Start();

                    // Đặt Void tại placementPoint (Tâm thực tế của dầm)
                    FamilyInstance voidInst = doc.Create.NewFamilyInstance(placementPoint, selectedVoidSymbol, Autodesk.Revit.DB.Structure.StructuralType.NonStructural);

                    // Xoay
                    RotateInstanceToVector(doc, voidInst, beamDir, placementPoint);

                    // Gán tham số
                    SetParam(voidInst, "Width", beamWidth);
                    SetParam(voidInst, "Height", beamHeight);
                    SetParam(voidInst, "Length", beamLength);

                    doc.Regenerate();

                    // Cắt
                    try
                    {
                        if (InstanceVoidCutUtils.CanBeCutWithVoid(wall))
                        {
                            InstanceVoidCutUtils.AddInstanceVoidCut(doc, wall, voidInst);
                        }
                        else
                        {
                            Autodesk.Revit.UI.TaskDialog.Show("Warning", "Tường không hỗ trợ cắt hoặc Void chưa chạm tường.");
                        }
                    }
                    catch (Exception ex)
                    {
                        // Bỏ qua lỗi nếu đã cắt rồi
                        System.Diagnostics.Debug.WriteLine(ex.Message);
                    }

                    t.Commit();
                }

                return Result.Succeeded;
            }
            catch (Autodesk.Revit.Exceptions.OperationCanceledException)
            {
                return Result.Cancelled;
            }
            catch (Exception ex)
            {
                message = ex.Message;
                return Result.Failed;
            }
        }

        // ====================================================
        //              CÁC HÀM HỖ TRỢ (HELPER METHODS)
        // ====================================================

        /// <summary>
        /// Lấy Solid có thể tích lớn nhất từ Element (để tìm tâm khối)
        /// </summary>
        private Solid GetSolidFromElement(Element elem)
        {
            Options opt = new Options();
            opt.DetailLevel = ViewDetailLevel.Fine; // Lấy mức chi tiết cao nhất
            opt.ComputeReferences = true;

            GeometryElement geoElem = elem.get_Geometry(opt);
            return GetSolidFromGeometryElement(geoElem);
        }

        private Solid GetSolidFromGeometryElement(GeometryElement geoElem)
        {
            if (geoElem == null) return null;

            Solid maxSolid = null;
            double maxVolume = 0;

            foreach (GeometryObject obj in geoElem)
            {
                Solid solid = obj as Solid;
                if (solid != null && solid.Volume > 0)
                {
                    if (solid.Volume > maxVolume)
                    {
                        maxVolume = solid.Volume;
                        maxSolid = solid;
                    }
                }
                else if (obj is GeometryInstance)
                {
                    GeometryInstance geoInst = obj as GeometryInstance;
                    // Đệ quy để tìm solid bên trong instance (nếu có)
                    Solid nestedSolid = GetSolidFromGeometryElement(geoInst.GetInstanceGeometry()); // Sử dụng GetInstanceGeometry để lấy tọa độ thế giới (nếu cần) hoặc GetSymbolGeometry
                    if (nestedSolid != null && nestedSolid.Volume > maxVolume)
                    {
                        maxVolume = nestedSolid.Volume;
                        maxSolid = nestedSolid;
                    }
                }
            }
            return maxSolid;
        }

        private double GetParamValueFromSymbol(FamilySymbol symbol, string[] paramNames)
        {
            if (symbol == null) return 0;
            ParameterSet paramSet = symbol.Parameters;
            foreach (Parameter param in paramSet)
            {
                foreach (string searchName in paramNames)
                {
                    if (param.Definition.Name.Equals(searchName, StringComparison.OrdinalIgnoreCase))
                    {
                        if (param.StorageType == StorageType.Double && param.HasValue) return param.AsDouble();
                    }
                }
            }
            return 0;
        }

        private double GetParamValue(Element elem, string[] paramNames)
        {
            if (elem == null) return 0;
            ParameterSet paramSet = elem.Parameters;
            foreach (Parameter param in paramSet)
            {
                foreach (string searchName in paramNames)
                {
                    if (param.Definition.Name.Equals(searchName, StringComparison.OrdinalIgnoreCase))
                    {
                        if (param.StorageType == StorageType.Double && param.HasValue) return param.AsDouble();
                    }
                }
            }
            return 0;
        }

        private void SetParam(Element elem, string paramName, double value)
        {
            Parameter p = elem.LookupParameter(paramName);
            if (p != null && !p.IsReadOnly) p.Set(value);
        }

        private void RotateInstanceToVector(Document doc, FamilyInstance inst, XYZ targetDir, XYZ center)
        {
            XYZ currentDir = inst.HandOrientation; // Hướng X của Void Family

            // Chỉ xoay trên mặt phẳng XY để tránh Void bị nghiêng theo chiều Z (nếu dầm nghiêng)
            // Nếu bạn muốn Void nghiêng theo dầm dốc, hãy bỏ dòng Flatten bên dưới
            // XYZ flatTarget = new XYZ(targetDir.X, targetDir.Y, 0).Normalize(); 

            double angle = currentDir.AngleTo(targetDir);

            if (Math.Abs(angle) > 0.001)
            {
                XYZ cross = currentDir.CrossProduct(targetDir);
                if (cross.IsZeroLength()) cross = XYZ.BasisZ;

                // Xác định chiều xoay
                if (cross.Z < 0) angle = -angle;

                Line axis = Line.CreateBound(center, center + XYZ.BasisZ);
                ElementTransformUtils.RotateElement(doc, inst.Id, axis, angle);
            }
        }

        public class WallSelectionFilter : ISelectionFilter
        {
            public bool AllowElement(Element elem) => elem.Category.Id.Value == (int)BuiltInCategory.OST_Walls;
            public bool AllowReference(Reference reference, XYZ position) => false;
        }

        public class FamilySelectionForm : System.Windows.Forms.Form
        {
            public FamilySymbol SelectedSymbol { get; private set; }
            private System.Windows.Forms.ComboBox cmbFamilies;
            private System.Windows.Forms.Button btnOk;
            private List<FamilySymbol> _symbols;

            public FamilySelectionForm(List<FamilySymbol> symbols)
            {
                _symbols = symbols;
                this.Text = "Chọn Family Void";
                this.Size = new System.Drawing.Size(300, 150);
                this.StartPosition = System.Windows.Forms.FormStartPosition.CenterScreen;
                this.AutoScaleDimensions = new System.Drawing.SizeF(6F, 13F);
                this.AutoScaleMode = System.Windows.Forms.AutoScaleMode.Font;

                cmbFamilies = new System.Windows.Forms.ComboBox() { Left = 20, Top = 20, Width = 240, DropDownStyle = System.Windows.Forms.ComboBoxStyle.DropDownList };
                foreach (var s in _symbols) cmbFamilies.Items.Add(s.Name);
                if (_symbols.Count > 0) cmbFamilies.SelectedIndex = 0;

                btnOk = new System.Windows.Forms.Button() { Text = "OK", Left = 100, Top = 60, DialogResult = System.Windows.Forms.DialogResult.OK };
                btnOk.Click += (s, e) => SelectedSymbol = _symbols[cmbFamilies.SelectedIndex];
                this.AcceptButton = btnOk;

                this.Controls.Add(cmbFamilies);
                this.Controls.Add(btnOk);
            }
        }
    }
}