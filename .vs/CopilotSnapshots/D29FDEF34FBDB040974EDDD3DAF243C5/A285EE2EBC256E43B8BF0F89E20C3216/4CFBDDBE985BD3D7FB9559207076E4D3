using System;
using System.Runtime.InteropServices;
using System.Diagnostics;
using System.IO;

namespace ArcTool.Core.Services
{
    public class ExcelInteropService : IDisposable
    {
        // Use dynamic object to avoid type conflicts between Excel COM versions
        private dynamic _excelApp;

        /// <summary>
        /// Connect to open Excel instance (Silent Mode)
        /// </summary>
        public bool AttachToActiveExcel()
        {
            try
            {
                // Get Excel instance running on Windows
                // Use reflection to call Marshal.GetActiveObject for .NET 8 compatibility
                var type = Type.GetType("System.Runtime.InteropServices.Marshal");
                if (type != null)
                {
                    var method = type.GetMethod("GetActiveObject", 
                        System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Static,
                        null, new[] { typeof(string) }, null);
                    
                    if (method != null)
                    {
                        object obj = method.Invoke(null, new[] { "Excel.Application" });
                        _excelApp = obj;
                        return _excelApp != null;
                    }
                }

                // Fallback: Create new instance using CreateObject
                _excelApp = Activator.CreateInstance(Type.GetTypeFromProgID("Excel.Application"));
                return _excelApp != null;
            }
            catch
            {
                return false; // Excel not found or error
            }
        }

        /// <summary>
        /// Copy print range, Paste to Chart and Export to SVG
        /// </summary>
        public bool ExportSelectionToSvg(string outputSvgPath, out string errorMsg)
        {
            errorMsg = string.Empty;
            if (_excelApp == null)
            {
                errorMsg = "Lost connection to Excel.";
                return false;
            }

            dynamic wb = null;
            dynamic sheet = null;
            dynamic targetRange = null;
            dynamic tempChart = null;

            try
            {
                if (!_excelApp.Ready)
                {
                    errorMsg = "Excel is busy (In Edit mode or dialog open).";
                    return false;
                }

                wb = _excelApp.ActiveWorkbook;
                if (wb == null)
                {
                    errorMsg = "No open Workbook found.";
                    return false;
                }

                sheet = wb.ActiveSheet;

                // --- SMART LOGIC STARTS HERE ---

                // 1. Priority: Get Print Area
                try
                {
                    string printAreaAddress = sheet.PageSetup.PrintArea;
                    if (!string.IsNullOrEmpty(printAreaAddress))
                    {
                        // Print Area returns address as string (e.g., "$A$1:$F$20")
                        targetRange = sheet.Range[printAreaAddress];
                        System.Diagnostics.Debug.WriteLine($"-> Found Print Area: {printAreaAddress}");
                    }
                }
                catch { /* Skip if Print Area lookup fails */ }

                // 2. If no Print Area, get current Selection
                if (targetRange == null)
                {
                    targetRange = _excelApp.Selection;
                    if (targetRange != null)
                    {
                        // Check if only 1 cell is selected and empty
                        if (targetRange.Count == 1)
                        {
                            try
                            {
                                if (string.IsNullOrEmpty(targetRange.Value2?.ToString()))
                                {
                                    targetRange = null; // Skip to step 3
                                }
                                else
                                {
                                    System.Diagnostics.Debug.WriteLine("-> Using current Selection.");
                                }
                            }
                            catch
                            {
                                targetRange = null;
                            }
                        }
                        else
                        {
                            System.Diagnostics.Debug.WriteLine("-> Using current Selection.");
                        }
                    }
                }

                // 3. Last resort: Get all used data range (UsedRange)
                if (targetRange == null)
                {
                    targetRange = sheet.UsedRange;
                    System.Diagnostics.Debug.WriteLine("-> No PrintArea/Selection, using UsedRange.");
                }

                // Final check
                if (targetRange == null)
                {
                    errorMsg = "Could not determine data range to export.";
                    return false;
                }

                // --- END SMART LOGIC ---

                // A. COPY AS PICTURE
                // Use numeric constants to avoid enum conflicts
                const int xlScreen = 1;           // XlPictureAppearance.xlScreen
                const int xlPicture = 2;          // XlCopyPictureFormat.xlPicture

                targetRange.CopyPicture(xlScreen, xlPicture);

                // B. CREATE CHART
                dynamic charts = sheet.ChartObjects();
                tempChart = charts.Add(0, 0, (double)targetRange.Width, (double)targetRange.Height);

                // C. PASTE & EXPORT
                tempChart.Activate();
                tempChart.Chart.Paste();
                tempChart.Chart.Export(outputSvgPath, "SVG");

                return true;
            }
            catch (Exception ex)
            {
                errorMsg = "Excel processing error: " + ex.Message;
                return false;
            }
            finally
            {
                // CLEANUP
                if (tempChart != null) try { tempChart.Delete(); } catch { }

                if (targetRange != null) Marshal.ReleaseComObject(targetRange);
                if (sheet != null) Marshal.ReleaseComObject(sheet);
                if (wb != null) Marshal.ReleaseComObject(wb);
            }
        }

        public void Dispose()
        {
            if (_excelApp != null)
            {
                try
                {
                    Marshal.ReleaseComObject(_excelApp);
                }
                catch { }
                _excelApp = null;
            }
        }
    }
}
