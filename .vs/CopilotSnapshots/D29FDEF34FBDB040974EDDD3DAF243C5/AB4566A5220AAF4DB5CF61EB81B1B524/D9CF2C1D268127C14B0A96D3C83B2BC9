using System;
using System.Runtime.InteropServices;
using System.Diagnostics;
using System.IO;
// B?t bu?c: Add Reference -> COM -> Microsoft Excel 16.0 Object Library
using Excel = Microsoft.Office.Interop.Excel;

namespace ArcTool.Core.Services
{
    public class ExcelInteropService : IDisposable
    {
        private Excel.Application _excelApp;

        /// <summary>
        /// 1. K?t n?i vào Excel ?ang m? (Silent Mode)
        /// </summary>
        public bool AttachToActiveExcel()
        {
            try
            {
                // L?y instance Excel ?ang ch?y trên Windows
                // S? d?ng reflection ?? g?i Marshal.GetActiveObject (t??ng thích .NET 8)
                var type = Type.GetType("System.Runtime.InteropServices.Marshal");
                if (type != null)
                {
                    var method = type.GetMethod("GetActiveObject", 
                        System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Static,
                        null, new[] { typeof(string) }, null);
                    
                    if (method != null)
                    {
                        object obj = method.Invoke(null, new[] { "Excel.Application" });
                        _excelApp = (Excel.Application)obj;
                        return _excelApp != null;
                    }
                }

                // Fallback: T?o instance m?i
                _excelApp = new Excel.Application();
                return _excelApp != null;
            }
            catch
            {
                return false; // Không tìm th?y Excel ?ang m?
            }
        }

        /// <summary>
        /// 2. Copy vùng in, Paste vào Chart và Xu?t ra SVG
        /// </summary>
        public bool ExportSelectionToSvg(string outputSvgPath)
        {
            if (_excelApp == null) return false;

            Excel.Workbook wb = null;
            Excel.Worksheet sheet = null;
            Excel.Range selection = null;
            Excel.ChartObject tempChart = null;

            try
            {
                wb = _excelApp.ActiveWorkbook;
                sheet = (Excel.Worksheet)wb.ActiveSheet;

                // L?y vùng ?ang ch?n ho?c UsedRange
                selection = _excelApp.Selection as Excel.Range;
                if (selection == null) return false;

                // A. COPY AS PICTURE (Vector Format)
                // xlPicture là m?u ch?t ?? ?nh nét khi zoom
                selection.CopyPicture(Excel.XlPictureAppearance.xlScreen, Excel.XlCopyPictureFormat.xlPicture);

                // B. T?O CHART T?M (WORKAROUND)
                var charts = (Excel.ChartObjects)sheet.ChartObjects();
                // T?o chart có kích th??c b?ng ?úng vùng ch?n
                tempChart = charts.Add(0, 0, (double)selection.Width, (double)selection.Height);

                // C. PASTE & EXPORT
                tempChart.Activate();
                tempChart.Chart.Paste();
                // FilterName "SVG" ch? có trên Excel 2016 tr? lên
                tempChart.Chart.Export(outputSvgPath, "SVG");

                return true;
            }
            catch (Exception ex)
            {
                Debug.WriteLine("Error: " + ex.Message);
                return false;
            }
            finally
            {
                // D. D?N D?P CHI?N TR??NG
                if (tempChart != null)
                {
                    try { tempChart.Delete(); } catch { } // Xóa chart ?? user không th?y
                }

                // Gi?i phóng COM objects ?? tránh treo Excel
                if (selection != null) Marshal.ReleaseComObject(selection);
                if (sheet != null) Marshal.ReleaseComObject(sheet);
                if (wb != null) Marshal.ReleaseComObject(wb);
            }
        }

        public void Dispose()
        {
            if (_excelApp != null)
            {
                Marshal.ReleaseComObject(_excelApp);
                _excelApp = null;
            }
        }
    }
}
