using System;
using System.Runtime.InteropServices;
using Microsoft.Office.Interop.Excel;
using Microsoft.Office.Core;
using Range = Microsoft.Office.Interop.Excel.Range;
using Application = Microsoft.Office.Interop.Excel.Application;

namespace ArcTool.Core.Services
{
    /// <summary>
    /// Service quản lý giao tiếp với Excel thông qua COM Interop.
    /// Updated V2: Hỗ trợ Export theo Print Area và tối ưu hóa reuse code.
    /// </summary>
    public class ExcelInteropService : IDisposable
    {
        private Application _excelApp;
        private Workbook _workbook;
        private Worksheet _activeSheet;

        // Configuration Constants
        private const int TARGET_DPI = 300; // High Quality for Revit
        private const int SCREEN_DPI = 72;  // Excel Base DPI

        public ExcelInteropService()
        {
        }

        public bool OpenFile(string filePath)
        {
            try
            {
                _excelApp = new Application();
                _excelApp.Visible = false;
                _excelApp.DisplayAlerts = false;
                _workbook = _excelApp.Workbooks.Open(filePath);
                _activeSheet = _workbook.ActiveSheet as Worksheet;
                return true;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Open Excel Error: {ex.Message}");
                return false;
            }
        }

        /// <summary>
        /// [NEW] Xuất ảnh dựa trên vùng in (Print Area) đã set trong Excel.
        /// </summary>
        public bool ExportPrintAreaAsHighResImage(string outputPath)
        {
            if (_activeSheet == null) return false;

            Range targetRange = null;
            try
            {
                // 1. Lấy địa chỉ Print Area
                string printAreaAddress = _activeSheet.PageSetup.PrintArea;

                // 2. Fallback: Nếu không có Print Area, dùng UsedRange
                if (string.IsNullOrEmpty(printAreaAddress))
                {
                    targetRange = _activeSheet.UsedRange;
                }
                else
                {
                    targetRange = _activeSheet.Range[printAreaAddress];
                }

                // 3. Gọi hàm Core để xử lý xuất ảnh
                return ExportRangeInternal(targetRange, outputPath);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Get PrintArea Error: {ex.Message}");
                return false;
            }
            // Note: Do not release targetRange here - it's a COM property managed by Excel
            // The COM interop layer will handle cleanup automatically
        }

        /// <summary>
        /// Xuất ảnh dựa trên địa chỉ vùng cụ thể (Legacy Support).
        /// </summary>
        public bool ExportRangeAsHighResImage(string rangeAddress, string outputPath)
        {
            if (_activeSheet == null) return false;
            Range targetRange = null;

            try
            {
                targetRange = _activeSheet.Range[rangeAddress];
                return ExportRangeInternal(targetRange, outputPath);
            }
            catch
            {
                return false;
            }
            // Note: Do not release targetRange - it's retrieved from the COM object property
        }

        /// <summary>
        /// [CORE] Logic cốt lõi: Scale Chart -> Paste -> Export.
        /// Access Modifier: Private (Encapsulation).
        /// </summary>
        private bool ExportRangeInternal(Range range, string outputPath)
        {
            ChartObjects chartObjects = null;
            ChartObject chartObj = null;
            Chart chart = null;

            try
            {
                // 1. Copy Vector (High Quality)
                range.CopyPicture(XlPictureAppearance.xlScreen, XlCopyPictureFormat.xlPicture);

                // 2. Tính toán Scale
                double scaleFactor = (double)TARGET_DPI / SCREEN_DPI;
                double width = (double)range.Width * scaleFactor;
                double height = (double)range.Height * scaleFactor;

                // 3. Tạo Chart tạm
                chartObjects = (ChartObjects)_activeSheet.ChartObjects();
                chartObj = chartObjects.Add(0, 0, width, height);
                chart = chartObj.Chart;

                // 4. Setup Canvas trong suốt
                chart.ChartArea.Format.Line.Visible = MsoTriState.msoFalse;
                chart.ChartArea.Fill.Visible = MsoTriState.msoFalse;

                // 5. Paste & Export
                chart.Paste();
                chart.Export(outputPath, "PNG", false);

                return true;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Core Export Error: {ex.Message}");
                return false;
            }
            finally
            {
                // Cleanup kỹ lưỡng để tránh process Excel bị treo
                if (chartObj != null)
                {
                    try { chartObj.Delete(); } catch { }
                }

                ReleaseObject(chart);
                ReleaseObject(chartObj);
                ReleaseObject(chartObjects);
                // Không release 'range' ở đây vì nó được truyền từ bên ngoài vào
            }
        }

        public void Dispose()
        {
            if (_workbook != null)
            {
                try { _workbook.Close(false); } catch { }
                ReleaseObject(_workbook);
            }
            if (_excelApp != null)
            {
                try { _excelApp.Quit(); } catch { }
                ReleaseObject(_excelApp);
            }

            // Force GC để dọn dẹp COM Objects còn sót
            GC.Collect();
            GC.WaitForPendingFinalizers();
        }

        private void ReleaseObject(object obj)
        {
            try
            {
                if (obj != null) Marshal.ReleaseComObject(obj);
            }
            catch { }
            finally { obj = null; }
        }
    }
}