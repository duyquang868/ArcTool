using System.Collections.Generic;
using System.Linq;
using Autodesk.Revit.Attributes;
using Autodesk.Revit.DB;
using Autodesk.Revit.UI;
using Arctool.UI; // Tham chiếu đến Project giao diện của bạn

namespace Arctool.Core.Commands
{
    [Transaction(TransactionMode.Manual)]
    public class FilterManagerCommand : IExternalCommand
    {
        public Result Execute(ExternalCommandData commandData, ref string message, ElementSet elements)
        {
            UIDocument uidoc = commandData.Application.ActiveUIDocument;
            Document doc = uidoc.Document;

            // 1. Khởi tạo cửa sổ giao diện Arctool
            FilterWindow ui = new FilterWindow();

            // Populate Filters
            var filters = new FilteredElementCollector(doc)
                .OfClass(typeof(ParameterFilterElement))
                .Cast<ParameterFilterElement>()
                .OrderBy(x => x.Name)
                .ToList();

            foreach (var f in filters)
            {
                ui.FiltersSource.Add(new FilterItem { Name = f.Name, Data = f });
            }

            // Populate Views
            var views = new FilteredElementCollector(doc)
                .OfClass(typeof(View))
                .Cast<View>()
                .Where(v => !v.IsTemplate && v.CanUseTemporaryVisibilityModes());

            foreach (var v in views)
            {
                ui.ViewsSource.Add(new ViewItem { ViewName = v.Name, FilterCount = v.GetFilters().Count, Data = v });
            }

            // 2. Gắn chủ sở hữu là Revit để cửa sổ không bị trôi
            var helper = new System.Windows.Interop.WindowInteropHelper(ui);
            helper.Owner = System.Diagnostics.Process.GetCurrentProcess().MainWindowHandle;

            // 3. Hiển thị hộp thoại
            if (ui.ShowDialog() == true)
            {
                using (Transaction t = new Transaction(doc, "Update Filters"))
                {
                    t.Start();

                    // Handle Deletions: Find filters in Revit that are no longer in the UI list
                    var remainingFilterIds = ui.FiltersSource
                        .Select(x => (x.Data as Element)?.Id)
                        .Where(id => id != null)
                        .ToList();

                    foreach (var f in filters)
                    {
                        if (!remainingFilterIds.Contains(f.Id))
                        {
                            doc.Delete(f.Id);
                        }
                    }

                    t.Commit();
                }
                return Result.Succeeded;
            }

            return Result.Cancelled;
        }
    }
}