<Window x:Class="Arctool.UI.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arctool - Copy Filters" Height="550" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="10" Background="#F5F5F5" BorderBrush="#D1D1D1" BorderThickness="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Background="White" Margin="0,0,5,0" Padding="10">
                    <TextBlock Text="View đang mở" FontSize="11" Foreground="Gray"/>
                    <TextBlock x:Name="txtActiveViewName" Text="Floor Plan: Level 1" FontWeight="SemiBold"/>
                </StackPanel>

                <UniformGrid Grid.Column="1" Columns="2">
                    <Button Content="View Templates" Background="White" BorderThickness="0" Margin="5,0"/>
                    <Button Content="Views/Sheets" Background="#FFC107" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                </UniformGrid>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="5" Margin="0,0,5,0">
                    <Grid Padding="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="Chọn Filter muốn copy" FontWeight="Bold"/>
                            <CheckBox HorizontalAlignment="Right"/>
                        </DockPanel>
                        <DataGrid Grid.Row="1" x:Name="dgFiltersCopy" ItemsSource="{Binding FiltersSource}" CanUserAddRows="False" AutoGenerateColumns="False" BorderThickness="0" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Select" Width="50" Binding="{Binding IsSelected}"/>
                                <DataGridTextColumn Header="Filter Name" Width="*" Binding="{Binding Name}"/>
                                <DataGridCheckBoxColumn Header="Enable" Width="50" Binding="{Binding IsEnabled}"/>
                                <DataGridCheckBoxColumn Header="Visibility" Width="60" Binding="{Binding IsVisible}"/>
                                <DataGridTemplateColumn Header="Override" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="5" Margin="5,0,0,0">
                    <Grid Padding="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="Chọn View muốn dán Filters" FontWeight="Bold"/>
                            <CheckBox HorizontalAlignment="Right"/>
                        </DockPanel>
                        <DataGrid Grid.Row="1" x:Name="dgViewsPaste" ItemsSource="{Binding ViewsSource}" CanUserAddRows="False" AutoGenerateColumns="False" BorderThickness="0" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="View Name" Width="*" Binding="{Binding ViewName}"/>
                                <DataGridTextColumn Header="Filters" Width="60" Binding="{Binding FilterCount}"/>
                                <DataGridCheckBoxColumn Width="30" Binding="{Binding IsSelected}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <UniformGrid Grid.Row="2" Columns="3" Margin="0,15,0,5">
                <Button Content="Y  Thêm Filters" Click="BtnAddFilters_Click" Height="40" Margin="0,0,10,0" Background="#FFC107" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
                <Button Content="Y  Xóa Filters" Click="BtnDeleteFilters_Click" Height="40" Margin="5,0" Background="#FFC107" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
                <Button Content="Y  Copy Filters" Click="BtnCopyFilters_Click" Height="40" Margin="10,0,0,0" Background="#FFC107" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</Window>