<Window x:Class="ArcTool.Core.UI.SyncStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArcTool — Excel Sync"
        Width="310" Height="68"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!-- Cho phép kéo window bằng cách click vào bất kỳ đâu -->
    <Border x:Name="RootBorder"
            CornerRadius="10"
            Background="#1E1E2E"
            BorderBrush="#3C3C5C"
            BorderThickness="1">

        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="16" Opacity="0.4" ShadowDepth="4"/>
        </Border.Effect>

        <Grid Margin="12,8,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- Tick indicator -->
                <ColumnDefinition Width="*"/>      <!-- Text -->
                <ColumnDefinition Width="Auto"/>   <!-- Update button -->
                <ColumnDefinition Width="Auto"/>   <!-- Close button -->
            </Grid.ColumnDefinitions>

            <!-- ── STATUS TICK INDICATOR ── -->
            <Grid Grid.Column="0" Width="28" Height="28"
                  Margin="0,0,10,0" VerticalAlignment="Center">

                <!-- Circle background -->
                <Ellipse x:Name="StatusDot"
                         Fill="#22C55E"/>

                <!-- Checkmark path — tọa độ được thiết kế cho canvas 28x28 -->
                <Path Data="M 7,14 L 12,19 L 21,9"
                      Stroke="White"
                      StrokeThickness="2.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"/>
            </Grid>

            <!-- ── TEXT AREA ── -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">

                <TextBlock x:Name="TxtFileName"
                           Text="Đang theo dõi..."
                           Foreground="#C8C8DC"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock x:Name="TxtStatus"
                           Text="Đã đồng bộ"
                           Foreground="#22C55E"
                           FontSize="10"
                           FontFamily="Segoe UI"
                           Margin="0,1,0,0"/>
            </StackPanel>

            <!-- ── UPDATE BUTTON ── -->
            <Button x:Name="BtnApply"
                    Grid.Column="2"
                    Content="Cập nhật"
                    Width="72" Height="28"
                    Margin="0,0,6,0"
                    IsEnabled="False"
                    Click="BtnApply_Click"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="11"
                    FontFamily="Segoe UI"
                    Cursor="Hand">

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#3B82F6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#2D3748"/>
                                            <Setter Property="Foreground" Value="#606070"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2563EB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- ── CLOSE BUTTON ── -->
            <Button Grid.Column="3"
                    Content="✕"
                    Width="22" Height="22"
                    VerticalAlignment="Top"
                    Click="BtnClose_Click"
                    BorderThickness="0"
                    FontSize="12"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#606070"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EF444420"/>
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
