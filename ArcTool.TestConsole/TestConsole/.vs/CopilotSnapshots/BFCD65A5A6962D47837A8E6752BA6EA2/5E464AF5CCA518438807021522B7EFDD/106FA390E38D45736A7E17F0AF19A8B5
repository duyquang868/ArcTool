using System;
using System.IO;
using ArcTool.Core.Services; // Gọi namespace chứa logic Excel

namespace ArcTool.TestConsole
{
    class Program
    {
        // là BẮT BUỘC để code tương tác với Clipboard và COM không bị lỗi

        static void Main(string[] args)
        {
            Console.OutputEncoding = System.Text.Encoding.UTF8;
            Console.WriteLine("--- TEST EXCEL INTEROP (AUTO DETECT PRINT AREA) ---");

            string desktopPath = Environment.GetFolderPath(Environment.SpecialFolder.Desktop);
            string outputPath = Path.Combine(desktopPath, "SmartExport.svg");

            if (File.Exists(outputPath)) File.Delete(outputPath);

            Console.WriteLine("-> Đang kiểm tra Excel...");

            using (var service = new ExcelInteropService())
            {
                if (!service.AttachToActiveExcel())
                {
                    Console.WriteLine("-> Lỗi: Không tìm thấy Excel đang mở.");
                    Console.WriteLine("   Hãy chắc chắn:");
                    Console.WriteLine("   1. Excel đã được mở");
                    Console.WriteLine("   2. Có ít nhất 1 workbook đang mở");
                    Console.WriteLine("   3. Bạn đã chọn một vùng dữ liệu (Range)");
                    DungManHinh();
                    return;
                }

                Console.WriteLine("-> Đã kết nối Excel. Đang tìm vùng in...");

                bool success = service.ExportSelectionToSvg(outputPath, out string errorMsg);

                if (success)
                {
                    Console.WriteLine($"-> XUẤT THÀNH CÔNG: {outputPath}");
                    try
                    {
                        System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo 
                        { 
                            FileName = outputPath, 
                            UseShellExecute = true 
                        });
                    }
                    catch { }
                }
                else
                {
                    Console.ForegroundColor = ConsoleColor.Red;
                    Console.WriteLine($"-> THẤT BẠI: {errorMsg}");
                    Console.ResetColor();
                }
            }

            DungManHinh();
        }

        static void DungManHinh()
        {
            Console.WriteLine("\nNhấn phím bất kỳ để thoát...");
            Console.ReadKey();
        }
    }
}