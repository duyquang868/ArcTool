<Window x:Class="Arctool.UI.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arctool - Copy Filters" Height="550" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="10" Background="#F5F5F5" BorderBrush="#D1D1D1" BorderThickness="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,-5,-5,10">
                <Button Content="—" Click="BtnMinimize_Click" Width="30" Height="25" Background="Transparent" BorderThickness="0"/>
                <Button Content="▢" Click="BtnMaximize_Click" Width="30" Height="25" Background="Transparent" BorderThickness="0"/>
                <Button Content="✕" Click="BtnClose_Click" Width="35" Height="25" Background="Transparent" Foreground="Red" BorderThickness="0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" Margin="0,0,5,0" Padding="10" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="View đang mở" FontSize="11" Foreground="Gray"/>
                        <TextBlock x:Name="txtActiveViewName" Text="Đang tải..." FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <UniformGrid Grid.Column="1" Columns="2">
                    <Button x:Name="btnViewTemplates" Content="View Templates" Click="BtnViewTemplates_Click" Background="White" BorderThickness="0" Margin="5,0"/>
                    <Button x:Name="btnViewsSheets" Content="Views/Sheets" Click="BtnViewsSheets_Click" Background="#E5F1FF" FontWeight="Bold" BorderThickness="0"/>
                </UniformGrid>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="5" Margin="0,0,5,0" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="Chọn Filter muốn copy" FontWeight="Bold"/>
                        </DockPanel>
                        <DataGrid Grid.Row="1" x:Name="dgFiltersCopy" CanUserAddRows="False" AutoGenerateColumns="False" BorderThickness="0" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Select" Width="50" Binding="{Binding IsSelected}"/>
                                <DataGridTextColumn Header="Filter Name" Width="*" Binding="{Binding Name}"/>
                                <DataGridCheckBoxColumn Header="Enable" Width="50" Binding="{Binding IsEnabled}"/>
                                <DataGridCheckBoxColumn Header="Visibility" Width="60" Binding="{Binding IsVisible}"/>
                                <DataGridTemplateColumn Header="Override" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="5" Margin="5,0,0,0" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="Chọn View muốn dán Filters" FontWeight="Bold"/>
                        </DockPanel>
                        <DataGrid Grid.Row="1" x:Name="dgViewsPaste" CanUserAddRows="False" AutoGenerateColumns="False" BorderThickness="0" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="View Name" Width="*" Binding="{Binding ViewName}"/>
                                <DataGridTextColumn Header="Filters" Width="60" Binding="{Binding FilterCount}"/>
                                <DataGridCheckBoxColumn Width="30" Binding="{Binding IsSelected}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <UniformGrid Grid.Row="3" Columns="3" Margin="0,15,0,5">
                <Button Content="Thêm Filters" Click="BtnAddFilters_Click" Height="40" Margin="0,0,10,0" Background="#E5F1FF" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Xóa Filters" Click="BtnDeleteFilters_Click" Height="40" Margin="5,0" Background="#E5F1FF" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Copy Filters" Click="BtnCopyFilters_Click" Height="40" Margin="10,0,0,0" Background="#E5F1FF" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</Window>